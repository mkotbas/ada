# =========================================
# .env (LOCAL GELİŞTİRME DOSYASI)
# =========================================

# KULLANIM:
# - Sadece 1 satırı aktif bırak
# - Diğerlerini # ile yorum satırı yap

# -----------------------------------------
# 1) LOCAL POCKETBASE (ÖNERİLEN)
# -----------------------------------------
VITE_POCKETBASE_URL=http://127.0.0.1:8090


# -----------------------------------------
# 2) ALTERNATİF LOCAL (IP DEĞİŞİRSE)
# -----------------------------------------
# VITE_POCKETBASE_URL=http://localhost:8090


# -----------------------------------------
# 3) GEÇİCİ TEST SUNUCUSU
# -----------------------------------------
# VITE_POCKETBASE_URL=https://test-api.fide.app


